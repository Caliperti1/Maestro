# Maestro local environment

# Example local Postgres URL.
DATABASE_URL=postgresql+psycopg://maestro:maestro@localhost:55432/maestro

# Set during implementation once auth exists.
APP_SECRET_KEY=

# Local development defaults.
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_PORT=5173
FRONTEND_ORIGIN=http://localhost:5173
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://0.0.0.0:5174
# Optional private remote frontend origin, for example a Tailscale address.
TAILSCALE_FRONTEND_ORIGIN=http://100.66.109.2:5173

# LLM-backed memory ingestion. OpenRouter is the local default gateway.
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_TITLE=Maestro
LLM_MODEL=openai/gpt-5.6-sol
# Per-work-item routing tiers. Profiles accept `default`, `ollama:<model>`,
# `openrouter:<provider/model>`, or `openai:<model>`.
LLM_QWEN_MODEL_PROFILE=ollama:qwen3:8b
LLM_LUNA_MODEL_PROFILE=openrouter:openai/gpt-5.6-luna
LLM_TERRA_MODEL_PROFILE=openrouter:openai/gpt-5.6-terra
LLM_SOL_MODEL_PROFILE=openrouter:openai/gpt-5.6-sol
# Keep the interactive channel responsive when the local classifier is unavailable or overloaded.
MAESTRO_INTENT_CLASSIFIER_TIMEOUT_SECONDS=10
MAESTRO_TOPIC_RESOLVER_TIMEOUT_SECONDS=10
MEMORY_DROPBOX_ROOT=maestro_dropbox
MEMORY_DROPBOX_AUTORUN=true
MEMORY_DROPBOX_INTERVAL_SECONDS=30
HOME_TIMEZONE=America/New_York

# Local-first semantic retrieval embeddings. Install with:
#   ollama pull nomic-embed-text
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_API_KEY=
EMBEDDING_DIMENSIONS=
MEMORY_EMBEDDING_BEST_EFFORT=true
